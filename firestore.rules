rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isLoggedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // 프로필: 누구나 읽기, 본인만 생성/수정, 로그인하면 삭제 가능
    match /profiles/{userId} {
      allow read: if true;
      allow create, update: if isOwner(userId);
      allow delete: if true;  // 관리자 삭제 허용
    }

    // 관리자 오버라이드: 누구나 읽기/쓰기
    match /adminOverrides/{userId} {
      allow read, write: if true;
    }

    // 삭제된 계정 목록
    match /deletedAccounts/{username} {
      allow read, write: if true;
    }

    // 티미팅: 누구나 읽기, 로그인하면 쓰기
    match /meetings/{meetingId} {
      allow read: if true;
      allow write: if true;  // 관리자 삭제 허용
    }

    // 게시글
    match /posts/{postId} {
      allow read: if true;
      allow create: if isLoggedIn();
      allow update: if isLoggedIn();
      allow delete: if true;  // 관리자 삭제 허용

      match /comments/{commentId} {
        allow read: if true;
        allow create: if isLoggedIn();
        allow delete: if true;
      }
    }

    // 채팅
    match /chats/{roomId}/messages/{msgId} {
      allow read: if true;
      allow create: if isLoggedIn();
      allow delete: if true;  // 관리자 초기화 허용
    }

    // 채팅방
    match /rooms/{roomId} {
      allow read: if true;
      allow create: if isLoggedIn();
      allow update: if isLoggedIn();
      allow delete: if true;  // 관리자 삭제 허용
    }

    // 일정
    match /events/{eventId} {
      allow read: if true;
      allow create: if isLoggedIn();
      allow update, delete: if isLoggedIn();
    }

    // 미션
    match /missions/{userId} {
      allow read: if true;
      allow write: if isOwner(userId);
      allow delete: if true;  // 관리자 삭제 허용
    }
  }
}
